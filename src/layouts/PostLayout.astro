---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import { formatPostDate, getReadingTime } from '../lib/posts';

interface Props {
  post: CollectionEntry<'posts'>;
  nextPost?: CollectionEntry<'posts'>;
  prevPost?: CollectionEntry<'posts'>;
  headings?: MarkdownHeading[];
}

const { post, nextPost, prevPost, headings = [] } = Astro.props;
const { title, date, tags, description, toc = true } = post.data;
const readingTime = getReadingTime(post.body);
const formattedDate = formatPostDate(date, 'long');
const tocItems = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
---

<BaseLayout title={title} description={description}>
  <article class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
    <header class="border-b border-neutral-200/90 pb-14 dark:border-neutral-800/90">
      <div class="grid gap-10 xl:grid-cols-[minmax(0,1fr)_16rem] xl:items-start">
        <div class="max-w-4xl">
          <p class="section-kicker animate-fade-up">{formattedDate}</p>
          <h1 class="animate-fade-up delay-100 mt-5 font-display text-display leading-[0.94] tracking-[-0.04em] text-neutral-950 dark:text-neutral-50">
            {title}
          </h1>

          {description && (
            <p class="animate-fade-up delay-200 mt-6 max-w-3xl font-serif text-[1.28rem] leading-relaxed text-neutral-700 dark:text-neutral-300 sm:text-[1.4rem]">
              {description}
            </p>
          )}

          <div class="animate-fade-up delay-300 mt-8 flex flex-wrap items-center gap-3 text-sm text-neutral-600 dark:text-neutral-300">
            <span class="tag-chip">{readingTime} min read</span>
            <span class="tag-chip">{tags.length} topic{tags.length !== 1 ? 's' : ''}</span>
            {tags.map((tag: string) => (
              <a href={`/tags/${tag.toLowerCase()}`} class="tag-chip">
                {tag}
              </a>
            ))}
          </div>
        </div>

        <div class="paper-panel p-6">
          <p class="note-panel-title">Article Notes</p>
          <div class="mt-5 space-y-5 text-sm leading-7 text-neutral-600 dark:text-neutral-300">
            <div>
              <p class="font-mono text-[0.68rem] uppercase tracking-[0.22em] text-neutral-500 dark:text-neutral-400">Published</p>
              <p class="mt-2">{formattedDate}</p>
            </div>
            <div>
              <p class="font-mono text-[0.68rem] uppercase tracking-[0.22em] text-neutral-500 dark:text-neutral-400">Reading Time</p>
              <p class="mt-2">{readingTime} minutes</p>
            </div>
            <div>
              <p class="font-mono text-[0.68rem] uppercase tracking-[0.22em] text-neutral-500 dark:text-neutral-400">Format</p>
              <p class="mt-2">Mathematical notebook entry with static MathJax rendering.</p>
            </div>
          </div>
        </div>
      </div>
    </header>

    <div class="mt-14 grid gap-12 xl:grid-cols-[minmax(0,1fr)_16rem]">
      <div class="min-w-0">
        <div class="max-w-[84ch]">
          <div class="prose prose-neutral dark:prose-invert max-w-none">
            <slot />
          </div>
        </div>

        <nav class="mt-18 grid gap-4 border-t border-neutral-200/90 pt-8 dark:border-neutral-800/90 md:grid-cols-2">
          {prevPost ? (
            <a href={`/posts/${prevPost.slug}`} class="post-nav-card">
              <span class="note-panel-title">Previous</span>
              <span class="mt-4 block font-display text-[1.35rem] leading-tight tracking-[-0.03em] text-neutral-900 dark:text-neutral-100">
                {prevPost.data.title}
              </span>
            </a>
          ) : (
            <div></div>
          )}

          {nextPost ? (
            <a href={`/posts/${nextPost.slug}`} class="post-nav-card text-left md:text-right">
              <span class="note-panel-title">Next</span>
              <span class="mt-4 block font-display text-[1.35rem] leading-tight tracking-[-0.03em] text-neutral-900 dark:text-neutral-100">
                {nextPost.data.title}
              </span>
            </a>
          ) : (
            <div></div>
          )}
        </nav>
      </div>

      {toc && tocItems.length > 0 && (
        <aside class="hidden xl:block">
          <div class="note-panel sticky top-32">
            <p class="note-panel-title">On This Page</p>
            <nav class="mt-5">
              <ul class="space-y-1">
                {tocItems.map((item) => (
                  <li>
                    <a href={`#${item.slug}`} class="toc-link" data-depth={item.depth}>
                      {item.text}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </div>
        </aside>
      )}
    </div>
  </article>
</BaseLayout>