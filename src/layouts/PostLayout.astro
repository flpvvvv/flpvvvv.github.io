---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
  nextPost?: CollectionEntry<'posts'>;
  prevPost?: CollectionEntry<'posts'>;
}

const { post, nextPost, prevPost } = Astro.props;
const { title, date, tags, description, toc = true } = post.data;

// Calculate reading time (approx 200 words per minute for technical content)
const words = post.body?.split(/\s+/).length || 0;
const readingTime = Math.max(1, Math.ceil(words / 200));

// Format date
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Generate TOC from headings
const headings = post.body?.match(/^#{1,3}\s+.+$/gm) || [];
const tocItems = headings
  .filter(h => h.startsWith('##'))
  .map(h => {
    const level = h.match(/^#+/)?.[0].length || 2;
    const text = h.replace(/^#+\s+/, '');
    const id = text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
    return { level, text, id };
  });
---

<BaseLayout title={title} description={description}>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Article Header -->
    <header class="mb-12">
      <h1 class="font-sans text-3xl sm:text-4xl lg:text-5xl font-bold text-neutral-900 dark:text-neutral-100 mb-6 leading-tight">
        {title}
      </h1>

      <div class="flex flex-wrap items-center gap-4 text-sm text-neutral-500 dark:text-neutral-400">
        <time datetime={date.toISOString()} class="flex items-center gap-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
          </svg>
          {formattedDate}
        </time>

        <span class="flex items-center gap-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          {readingTime} min read
        </span>
      </div>

      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {tags.map((tag: string) => (
            <a href={`/tags/${tag.toLowerCase()}`} class="tag">
              {tag}
            </a>
          ))}
        </div>
      )}
    </header>

    <!-- Article Content with optional TOC -->
    <div class="lg:grid lg:grid-cols-[1fr_250px] lg:gap-12 lg:max-w-none">
      <!-- Main Content -->
      <div class="prose prose-neutral dark:prose-invert max-w-none">
        <slot />
      </div>

      <!-- Table of Contents (desktop only) -->
      {toc && tocItems.length > 0 && (
        <aside class="hidden lg:block">
          <nav class="sticky top-24">
            <h2 class="font-sans text-sm font-semibold text-neutral-900 dark:text-neutral-100 uppercase tracking-wider mb-4">
              On this page
            </h2>
            <ul class="space-y-1 border-l border-neutral-200 dark:border-neutral-700">
              {tocItems.map((item: { level: number; text: string; id: string }) => (
                <li>
                  <a href={`#${item.id}`} class="toc-link">
                    {item.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </aside>
      )}
    </div>

    <!-- Navigation -->
    <nav class="mt-16 pt-8 border-t border-neutral-200 dark:border-neutral-700">
      <div class="grid grid-cols-2 gap-4">
        {prevPost ? (
          <a href={`/posts/${prevPost.slug}`} class="group p-4 rounded-lg border border-neutral-200 dark:border-neutral-700 hover:border-primary-500 dark:hover:border-primary-500 transition-colors">
            <span class="block text-sm text-neutral-500 dark:text-neutral-400 mb-1">Previous</span>
            <span class="font-medium text-neutral-900 dark:text-neutral-100 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
              {prevPost.data.title}
            </span>
          </a>
        ) : (
          <div></div>
        )}
        {nextPost ? (
          <a href={`/posts/${nextPost.slug}`} class="group p-4 rounded-lg border border-neutral-200 dark:border-neutral-700 hover:border-primary-500 dark:hover:border-primary-500 transition-colors text-right">
            <span class="block text-sm text-neutral-500 dark:text-neutral-400 mb-1">Next</span>
            <span class="font-medium text-neutral-900 dark:text-neutral-100 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
              {nextPost.data.title}
            </span>
          </a>
        ) : (
          <div></div>
        )}
      </div>
    </nav>
  </article>
</BaseLayout>