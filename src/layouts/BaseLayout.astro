---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = 'flpvvvv is a data scientist publishing long-form field notes on statistics, inference, probability, and machine learning methods.',
  image = '/images/social.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const pathname = Astro.url.pathname;
const navItems = [
  { href: '/posts/', label: 'Archive' },
  { href: '/tags/', label: 'Topics' },
  { href: '/about/', label: 'About' },
];
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{title} | flpvvvv</title>
    <meta name="title" content={`${title} | flpvvvv`} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | flpvvvv`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={`${title} | flpvvvv`} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.site)} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT@9..144,300..700,0..100&family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600;700&family=Source+Serif+4:opsz,wght@8..60,400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon.png" />

    <!-- Theme color -->
    <meta name="theme-color" content="#2f6963" />

    <ClientRouter />

    <script is:inline>
      function applyTheme() {
        const stored = typeof localStorage !== 'undefined' ? localStorage.getItem('theme') : null;
        const system =
          typeof window !== 'undefined' && window.matchMedia('(prefers-color-scheme: dark)').matches
            ? 'dark'
            : 'light';
        const theme = stored || system;
        document.documentElement.classList.remove('light', 'dark');
        document.documentElement.classList.add(theme);
      }
      applyTheme();
      document.addEventListener('astro:after-swap', applyTheme);
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <div class="dot-grid" aria-hidden="true"></div>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:z-50 focus:top-2 focus:left-2 focus:rounded focus:bg-white focus:px-4 focus:py-2 focus:text-primary-700 focus:shadow-lg dark:focus:bg-neutral-900 dark:focus:text-primary-300">Skip to content</a>
    <div id="reading-progress" style="width: 0%"></div>

    <header class="sticky top-0 z-40 border-b border-neutral-200/80 bg-neutral-50/90 backdrop-blur-xl dark:border-neutral-800/85 dark:bg-neutral-950/88">
      <nav class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between gap-4 py-3.5 lg:py-0">
          <a href="/" class="group min-w-0 flex-1 lg:py-5">
            <span class="hidden text-[0.68rem] section-kicker sm:block">
              flpvvvv
            </span>
            <span class="block truncate font-display text-[1.45rem] leading-none tracking-[-0.04em] text-neutral-950 transition-colors duration-300 group-hover:text-primary-700 dark:text-neutral-50 dark:group-hover:text-primary-300 sm:mt-1.5 sm:text-[2rem] lg:text-[2.45rem]">
              Field Notes in Statistics
            </span>
            <span class="mt-1 hidden max-w-lg text-sm leading-6 text-neutral-600 dark:text-neutral-300 sm:block">
              Data scientist. Long-form writing on inference, probability, and machine learning.
            </span>
          </a>

          <div class="hidden items-center gap-7 lg:flex lg:py-5">
            {navItems.map((item) => {
              const isActive =
                item.href === '/'
                  ? pathname === item.href
                  : pathname === item.href || pathname.startsWith(`${item.href}/`);
              return (
                <a href={item.href} class="nav-link" aria-current={isActive ? 'page' : undefined}>
                  {item.label}
                </a>
              );
            })}
            <button id="theme-toggle" class="theme-toggle" aria-label="Toggle dark mode">
              <svg class="hidden h-5 w-5 dark:block" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd"></path>
              </svg>
              <svg class="block h-5 w-5 dark:hidden" fill="currentColor" viewBox="0 0 20 20">
                <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path>
              </svg>
            </button>
          </div>

          {/* Mobile controls */}
          <div class="flex items-center gap-2 lg:hidden">
            <button id="theme-toggle-mobile" class="theme-toggle !h-11 !w-11" aria-label="Toggle dark mode">
              <svg class="hidden h-[18px] w-[18px] dark:block" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd"></path>
              </svg>
              <svg class="block h-[18px] w-[18px] dark:hidden" fill="currentColor" viewBox="0 0 20 20">
                <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path>
              </svg>
            </button>
            <button
              id="mobile-nav-toggle"
              class="flex h-11 w-11 items-center justify-center rounded-full border border-neutral-300/80 bg-white/60 text-neutral-600 transition-colors duration-200 hover:text-neutral-900 active:scale-95 dark:border-neutral-700/80 dark:bg-neutral-900/70 dark:text-neutral-300 dark:hover:text-neutral-50"
              aria-label="Open menu"
              aria-expanded="false"
              aria-controls="mobile-nav-overlay"
            >
              <svg class="h-[18px] w-[18px]" id="nav-icon-open" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"></path>
              </svg>
              <svg class="hidden h-[18px] w-[18px]" id="nav-icon-close" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </button>
          </div>
        </div>
      </nav>
    </header>

    {/* Full-screen mobile navigation overlay */}
    <div
      id="mobile-nav-overlay"
      class="fixed inset-0 z-50 flex flex-col items-center justify-center bg-neutral-50/97 opacity-0 pointer-events-none backdrop-blur-2xl transition-opacity duration-300 dark:bg-neutral-950/97 lg:!hidden"
      role="dialog"
      aria-label="Navigation menu"
    >
      <button
        id="mobile-nav-close"
        class="absolute right-4 top-4 flex h-11 w-11 items-center justify-center rounded-full border border-neutral-300/80 bg-white/60 text-neutral-600 transition-colors duration-200 hover:text-neutral-900 active:scale-95 dark:border-neutral-700/80 dark:bg-neutral-900/70 dark:text-neutral-300 dark:hover:text-neutral-50"
        aria-label="Close menu"
      >
        <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>

      <nav class="flex flex-col items-center gap-2">
        {navItems.map((item) => {
          const isActive =
            item.href === '/'
              ? pathname === item.href
              : pathname === item.href || pathname.startsWith(`${item.href}/`);
          return (
            <a
              href={item.href}
              class:list={[
                'mobile-overlay-link translate-y-4 opacity-0 rounded-2xl px-8 py-4 text-center font-display text-[2rem] leading-tight tracking-[-0.03em] transition-all duration-300 ease-out',
                isActive
                  ? 'text-primary-700 dark:text-primary-300'
                  : 'text-neutral-800 hover:text-primary-700 dark:text-neutral-200 dark:hover:text-primary-300',
              ]}
              aria-current={isActive ? 'page' : undefined}
            >
              {item.label}
            </a>
          );
        })}
      </nav>

      <p class="absolute bottom-8 font-mono text-[0.68rem] uppercase tracking-[0.22em] text-neutral-500 dark:text-neutral-400">
        flpvvvv &middot; Field Notes
      </p>
    </div>

    <main id="main-content" class="flex-1 relative z-10">
      <slot />
    </main>

    <footer class="relative z-10 border-t border-neutral-200/80 bg-neutral-50/78 backdrop-blur-sm dark:border-neutral-800/85 dark:bg-neutral-950/74">
      <div class="mx-auto grid max-w-6xl gap-8 px-4 py-10 sm:px-6 sm:py-12 lg:grid-cols-[minmax(0,1.4fr)_minmax(0,1fr)_auto] lg:px-8">
        <div>
          <p class="section-kicker mb-2 text-[0.68rem] sm:mb-3">flpvvvv</p>
          <p class="max-w-xl font-display text-[1.4rem] leading-tight tracking-[-0.035em] text-neutral-950 dark:text-neutral-50 sm:text-[1.75rem] sm:leading-none">
            An editorial notebook for mathematical thinking.
          </p>
          <p class="mt-2.5 max-w-xl text-[0.82rem] leading-6 text-neutral-600 dark:text-neutral-300 sm:mt-3 sm:text-sm">
            Built as a static publication with Astro and compile-time MathJax, designed to let dense equations breathe.
          </p>
        </div>

        <div class="flex gap-6 text-sm leading-7 text-neutral-600 dark:text-neutral-300 lg:grid lg:gap-2">
          <a href="/posts/" class="hover:text-neutral-950 dark:hover:text-neutral-50">Archive</a>
          <a href="/tags/" class="hover:text-neutral-950 dark:hover:text-neutral-50">Topics</a>
          <a href="/about/" class="hover:text-neutral-950 dark:hover:text-neutral-50">About</a>
        </div>

        <div class="flex items-center gap-6 lg:flex-col lg:items-end lg:gap-4">
          <div class="flex items-center gap-4">
            <a href="mailto:flpvvvv@live.com" class="flex h-10 w-10 items-center justify-center rounded-full text-neutral-500 hover:text-primary-700 dark:text-neutral-400 dark:hover:text-primary-300" aria-label="Email">
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"></path>
                <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"></path>
              </svg>
              <span class="sr-only">Email</span>
            </a>
            <a href="https://github.com/flpvvvv" target="_blank" rel="noopener noreferrer" class="flex h-10 w-10 items-center justify-center rounded-full text-neutral-500 hover:text-primary-700 dark:text-neutral-400 dark:hover:text-primary-300" aria-label="GitHub">
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path>
              </svg>
              <span class="sr-only">GitHub</span>
            </a>
          </div>

          <p class="font-mono text-[0.68rem] uppercase tracking-[0.18em] text-neutral-500 dark:text-neutral-400 sm:text-[0.72rem]">
            &copy; {new Date().getFullYear()} flpvvvv
          </p>
        </div>
      </div>
    </footer>

    <script is:inline>
      function initPage() {
        const setTheme = (theme) => {
          document.documentElement.classList.remove('light', 'dark');
          document.documentElement.classList.add(theme);
          localStorage.setItem('theme', theme);
        };

        const toggleTheme = () => {
          const current = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
          setTheme(current === 'dark' ? 'light' : 'dark');
        };

        document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);
        document.getElementById('theme-toggle-mobile')?.addEventListener('click', toggleTheme);

        // Mobile nav overlay
        const mobileNavToggle = document.getElementById('mobile-nav-toggle');
        const mobileNavOverlay = document.getElementById('mobile-nav-overlay');
        const navIconOpen = document.getElementById('nav-icon-open');
        const navIconClose = document.getElementById('nav-icon-close');
        const mobileNavClose = document.getElementById('mobile-nav-close');

        function openMobileNav() {
          if (!mobileNavOverlay) return;
          mobileNavOverlay.classList.remove('pointer-events-none', 'opacity-0');
          mobileNavOverlay.classList.add('pointer-events-auto', 'opacity-100');
          mobileNavToggle?.setAttribute('aria-expanded', 'true');
          navIconOpen?.classList.add('hidden');
          navIconClose?.classList.remove('hidden');
          document.body.style.overflow = 'hidden';
          mobileNavOverlay.querySelectorAll('.mobile-overlay-link').forEach((link, i) => {
            link.style.transitionDelay = `${80 + i * 50}ms`;
            link.classList.remove('translate-y-4', 'opacity-0');
          });
        }

        function closeMobileNav() {
          if (!mobileNavOverlay) return;
          mobileNavOverlay.querySelectorAll('.mobile-overlay-link').forEach((link) => {
            link.style.transitionDelay = '0ms';
            link.classList.add('translate-y-4', 'opacity-0');
          });
          setTimeout(() => {
            mobileNavOverlay.classList.add('pointer-events-none', 'opacity-0');
            mobileNavOverlay.classList.remove('pointer-events-auto', 'opacity-100');
          }, 120);
          mobileNavToggle?.setAttribute('aria-expanded', 'false');
          navIconOpen?.classList.remove('hidden');
          navIconClose?.classList.add('hidden');
          document.body.style.overflow = '';
        }

        mobileNavToggle?.addEventListener('click', () => {
          const isOpen = mobileNavToggle.getAttribute('aria-expanded') === 'true';
          isOpen ? closeMobileNav() : openMobileNav();
        });
        mobileNavClose?.addEventListener('click', closeMobileNav);
        mobileNavOverlay?.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', () => setTimeout(closeMobileNav, 80));
        });

        // Reading progress
        const progressBar = document.getElementById('reading-progress');
        if (progressBar) {
          let ticking = false;
          const updateProgress = () => {
            const scrollTop = window.scrollY;
            const docHeight = document.documentElement.scrollHeight - window.innerHeight;
            if (docHeight <= 0) { progressBar.style.width = '0%'; ticking = false; return; }
            progressBar.style.width = `${Math.min((scrollTop / docHeight) * 100, 100)}%`;
            ticking = false;
          };
          window.addEventListener('scroll', () => {
            if (!ticking) { requestAnimationFrame(updateProgress); ticking = true; }
          }, { passive: true });
          updateProgress();
        }
      }
      initPage();
      document.addEventListener('astro:after-swap', initPage);
    </script>
  </body>
</html>