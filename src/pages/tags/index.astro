---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTagCounts, slugifyTag, sortPublishedPosts } from '../../lib/posts';

const posts = sortPublishedPosts(await getCollection('posts'));
const tagCounts = getTagCounts(posts);
const tags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="Topics — Browse the Notebook by Subject" description="Explore notebook entries organized by topic: statistics, machine learning, probability, Bayesian inference, and more.">
  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
    <header class="mb-10 max-w-3xl sm:mb-14">
      <p class="section-kicker">Topics</p>
      <h1 class="mt-4 font-display text-display text-neutral-950 dark:text-neutral-50 sm:mt-5">
        A subject index for the archive
      </h1>
      <p class="mt-4 font-serif text-[1.1rem] leading-relaxed text-neutral-700 dark:text-neutral-300 sm:mt-6 sm:text-[1.28rem]">
        Browse the notebook by topic instead of chronology. Each tag groups entries around a recurring idea, method, or problem.
      </p>
    </header>

    <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_18rem]">
      <div class="paper-panel p-8 sm:p-10">
        <div class="flex flex-wrap gap-3">
          {tags.map(([tag, count]) => (
            <a href={`/tags/${slugifyTag(tag)}/`} class="tag-chip">
              <span>#{tag}</span>
              <span class="text-neutral-500 dark:text-neutral-400">{count}</span>
            </a>
          ))}
        </div>
      </div>

      <aside class="space-y-6">
        <div class="paper-panel p-6">
          <p class="note-panel-title">Index</p>
          <p class="mt-4 text-sm leading-7 text-neutral-700 dark:text-neutral-300">
            {tags.length} topic{tags.length !== 1 ? 's' : ''} across {posts.length} published entries.
          </p>
        </div>
        <div class="paper-panel p-6">
          <p class="note-panel-title">Reading Strategy</p>
          <p class="mt-4 text-sm leading-7 text-neutral-700 dark:text-neutral-300">
            Use tags to follow a concept across posts, then move into the chronological archive when you want the full sequence of study.
          </p>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>