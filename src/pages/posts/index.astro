---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatPostDate, getReadingTime, groupPostsByYear, sortPublishedPosts } from '../../lib/posts';

const posts = sortPublishedPosts(await getCollection('posts'));
const postsByYear = groupPostsByYear(posts);
const years = Object.keys(postsByYear).map(Number).sort((a, b) => b - a);
---

<BaseLayout title="Archive — All Notebook Entries" description="Browse every entry in the notebook: long-form notes on statistics, probability, estimation, hypothesis testing, and Bayesian methods.">
  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
    <header class="mb-10 max-w-3xl sm:mb-14">
      <p class="section-kicker">Archive</p>
      <h1 class="mt-4 font-display text-display text-neutral-950 dark:text-neutral-50 sm:mt-5">
        Every post, ordered like a bound volume
      </h1>
      <p class="mt-4 font-serif text-[1.1rem] leading-relaxed text-neutral-700 dark:text-neutral-300 sm:mt-6 sm:text-[1.28rem]">
        A chronological archive of the notebook: statistics, machine learning, and the surrounding methods that make quantitative reasoning useful.
      </p>
    </header>

    <div class="grid gap-12 xl:grid-cols-[14rem_minmax(0,1fr)]">
      <aside class="hidden xl:block">
        <div class="note-panel sticky top-32">
          <p class="note-panel-title">Archive Facts</p>
          <p class="mt-4 text-sm leading-7 text-neutral-700 dark:text-neutral-300">
            {posts.length} entries collected across {years.length} publication year{years.length !== 1 ? 's' : ''}.
          </p>
        </div>
      </aside>

      <div class="space-y-16">
        {years.map((year) => (
          <section>
            <div class="mb-6 flex items-end gap-3 sm:mb-8 sm:gap-4">
              <h2 class="font-display text-[2.8rem] leading-none tracking-[-0.05em] text-neutral-300 dark:text-neutral-700 sm:text-[4rem]">
                {year}
              </h2>
              <span class="archive-meta pb-1 sm:pb-2">
                {postsByYear[year].length} post{postsByYear[year].length !== 1 ? 's' : ''}
              </span>
            </div>

            <div>
              {postsByYear[year].map((post) => (
                <a href={`/posts/${post.slug}/`} class="archive-row">
                  <time datetime={post.data.date.toISOString()}>{formatPostDate(post.data.date, 'short')}</time>
                  <div>
                    <h3 class="archive-title">{post.data.title}</h3>
                    {post.data.description && (
                      <p class="archive-summary">{post.data.description}</p>
                    )}
                    {post.data.tags.length > 0 && (
                      <div class="mt-4 flex flex-wrap gap-2">
                        {post.data.tags.map((tag: string) => (
                          <span class="tag-chip">#{tag}</span>
                        ))}
                      </div>
                    )}
                  </div>
                  <div class="archive-meta flex items-center gap-3 md:justify-end">
                    <span>{getReadingTime(post.body)} min</span>
                    <svg class="h-4 w-4 text-primary-700 dark:text-primary-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                  </div>
                </a>
              ))}
            </div>
          </section>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>