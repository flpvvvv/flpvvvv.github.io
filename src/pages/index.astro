---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { formatPostDate, getReadingTime, getTagCounts, slugifyTag, sortPublishedPosts } from '../lib/posts';

const posts = sortPublishedPosts(await getCollection('posts'));
const [featuredPost, ...recentPosts] = posts;
const tagCounts = Object.entries(getTagCounts(posts)).sort((a, b) => b[1] - a[1]);
const yearRange = posts.length
  ? `${posts.at(-1)?.data.date.getFullYear()}-${posts[0].data.date.getFullYear()}`
  : null;
---

<BaseLayout title="Field Notes on Statistics & Inference">
  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
    <div class="grid gap-8 sm:gap-10 xl:grid-cols-[minmax(0,1.15fr)_21rem] xl:items-start">
      <div>
        <div class="flex items-start gap-5 sm:block xl:block">
          <div class="portrait-frame animate-fade-up delay-200 w-20 shrink-0 sm:hidden">
            <img src="/images/profile.jpg" alt="Portrait of flpvvvv" width="400" height="400" loading="eager" />
          </div>
          <div class="min-w-0">
            <p class="section-kicker animate-fade-up">Research Notebook</p>
            <h1 class="animate-fade-up delay-100 mt-3 font-display text-hero text-neutral-950 dark:text-neutral-50 sm:mt-5">
              flpvvvv
            </h1>
          </div>
        </div>
        <p class="animate-fade-up delay-200 mt-5 max-w-3xl font-serif text-[1.15rem] leading-relaxed text-neutral-700 dark:text-neutral-300 sm:mt-6 sm:text-[1.35rem] lg:text-[1.52rem]">
          A blog-first bio site for mathematical writing: statistics, inference, and machine learning presented with the calm of a journal and the precision of a notebook.
        </p>

        <div class="animate-fade-up delay-300 mt-6 flex flex-wrap gap-3 sm:mt-8">
          <a href="/posts/" class="button-solid">
            Read the archive
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
          <a href="/about/" class="button-ghost">About the author</a>
        </div>

        <div class="animate-fade-up delay-400 mt-8 grid gap-3 sm:mt-10 sm:gap-4 md:grid-cols-3">
          <div class="paper-panel p-4 sm:p-5">
            <p class="note-panel-title">Archive</p>
            <p class="mt-2 font-display text-[1.8rem] leading-none tracking-[-0.04em] text-neutral-950 dark:text-neutral-50 sm:mt-3 sm:text-[2.1rem]">
              {posts.length}
            </p>
            <p class="mt-1.5 text-[0.82rem] leading-6 text-neutral-600 dark:text-neutral-300 sm:mt-2 sm:text-sm">
              Long-form entries spanning {yearRange}.
            </p>
          </div>

          <div class="paper-panel p-4 sm:p-5">
            <p class="note-panel-title">Focus</p>
            <p class="mt-2 font-display text-[1.8rem] leading-none tracking-[-0.04em] text-neutral-950 dark:text-neutral-50 sm:mt-3 sm:text-[2.1rem]">
              Math-first
            </p>
            <p class="mt-1.5 text-[0.82rem] leading-6 text-neutral-600 dark:text-neutral-300 sm:mt-2 sm:text-sm">
              Dense statistical equations rendered statically with MathJax.
            </p>
          </div>

          <div class="paper-panel p-4 sm:p-5">
            <p class="note-panel-title">Topics</p>
            <p class="mt-2 font-display text-[1.8rem] leading-none tracking-[-0.04em] text-neutral-950 dark:text-neutral-50 sm:mt-3 sm:text-[2.1rem]">
              {tagCounts.length}
            </p>
            <p class="mt-1.5 text-[0.82rem] leading-6 text-neutral-600 dark:text-neutral-300 sm:mt-2 sm:text-sm">
              Themes indexed across the notebook.
            </p>
          </div>
        </div>
      </div>

      <div class="hidden gap-4 sm:grid xl:grid">
        <div class="portrait-frame animate-fade-up delay-200">
          <img src="/images/profile.jpg" alt="Portrait of flpvvvv" width="400" height="400" loading="eager" />
        </div>

        <div class="paper-panel animate-fade-up delay-300 p-6">
          <p class="note-panel-title">Abstract</p>
          <p class="mt-4 text-sm leading-7 text-neutral-700 dark:text-neutral-300">
            This site turns personal study into a public archive. The writing is grounded in rigorous mathematics, but the presentation is designed to feel open, quiet, and legible rather than intimidating.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="section-rule"></div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 sm:py-20 lg:grid lg:grid-cols-[minmax(0,1.15fr)_21rem] lg:gap-10 lg:px-8">
    <div>
      <div class="flex items-end justify-between gap-4">
        <div>
          <p class="section-kicker">Latest Writing</p>
          <h2 class="mt-3 font-display text-heading text-neutral-950 dark:text-neutral-50 sm:mt-4">
            Recent entries from the archive
          </h2>
        </div>
        <a href="/posts/" class="hidden shrink-0 font-mono text-[0.72rem] uppercase tracking-[0.18em] text-primary-700 hover:text-primary-900 dark:text-primary-300 dark:hover:text-primary-200 md:block">
          Browse all posts
        </a>
      </div>

      {featuredPost && (
        <a href={`/posts/${featuredPost.slug}/`} class="paper-panel mt-6 block p-5 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg sm:mt-8 sm:p-8">
          <p class="section-kicker">{formatPostDate(featuredPost.data.date, 'medium')}</p>
          <h3 class="mt-3 font-display text-[1.8rem] leading-[0.95] tracking-[-0.04em] text-neutral-950 dark:text-neutral-50 sm:mt-5 sm:text-[2.55rem]">
            {featuredPost.data.title}
          </h3>
          {featuredPost.data.description && (
            <p class="mt-3 max-w-3xl font-serif text-[1rem] leading-7 text-neutral-700 dark:text-neutral-300 sm:mt-5 sm:text-[1.15rem] sm:leading-8">
              {featuredPost.data.description}
            </p>
          )}
          <div class="mt-4 flex flex-wrap gap-2 text-sm text-neutral-600 dark:text-neutral-300 sm:mt-6 sm:gap-3">
            <span class="tag-chip">{getReadingTime(featuredPost.body)} min read</span>
            {featuredPost.data.tags.slice(0, 3).map((tag: string) => (
              <span class="tag-chip">#{tag}</span>
            ))}
          </div>
        </a>
      )}

      <div class="mt-6 sm:mt-8">
        {recentPosts.slice(0, 4).map((post) => (
          <a href={`/posts/${post.slug}/`} class="archive-row">
            <time datetime={post.data.date.toISOString()}>{formatPostDate(post.data.date, 'short')}</time>
            <div>
              <h3 class="archive-title">{post.data.title}</h3>
              {post.data.description && (
                <p class="archive-summary">{post.data.description}</p>
              )}
            </div>
            <div class="archive-meta flex items-center gap-3 md:justify-end">
              <span>{getReadingTime(post.body)} min</span>
              <svg class="h-4 w-4 text-primary-700 dark:text-primary-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </div>
          </a>
        ))}
      </div>

      <a href="/posts/" class="mt-6 flex items-center gap-2 font-mono text-[0.72rem] uppercase tracking-[0.18em] text-primary-700 hover:text-primary-900 dark:text-primary-300 dark:hover:text-primary-200 md:hidden" aria-label="Browse all posts">
        Browse all posts
        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path>
        </svg>
      </a>
    </div>

    <aside class="mt-10 space-y-6 lg:mt-0">
      <div class="paper-panel p-5 sm:p-6">
        <p class="note-panel-title">Topic Index</p>
        <div class="mt-4 flex flex-wrap gap-2 sm:mt-5 sm:gap-2.5">
          {tagCounts.map(([tag, count]) => (
            <a href={`/tags/${slugifyTag(tag)}/`} class="tag-chip">
              {tag}
              <span class="text-neutral-500 dark:text-neutral-400">{count}</span>
            </a>
          ))}
        </div>
      </div>

      <div class="paper-panel p-5 sm:p-6">
        <p class="note-panel-title">Lineage</p>
        <p class="mt-3 text-[0.85rem] leading-7 text-neutral-700 dark:text-neutral-300 sm:mt-4 sm:text-sm">
          Many essays grew from notes on the MITx 18.6501x Fundamentals of Statistics course, then evolved into a more personal archive of methods, proofs, and intuition.
        </p>
      </div>
    </aside>
  </section>
</BaseLayout>