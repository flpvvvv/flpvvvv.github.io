---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('posts'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Get unique tags
const allTags = [...new Set(posts.flatMap(post => post.data.tags))];
---

<BaseLayout title="Home">
  <!-- Hero Section -->
  <section class="relative overflow-hidden">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28 lg:py-32">
      <div class="max-w-3xl">
        <!-- Dramatic name with tight letter-spacing -->
        <p class="hero-animate font-mono text-sm text-primary-600 dark:text-primary-400 mb-6 tracking-widest uppercase">
          Data Scientist
        </p>

        <h1 class="hero-animate text-hero font-bold text-neutral-900 dark:text-neutral-100 mb-8 tracking-tight leading-[1.1]">
          Hello, I'm<br />
          <span class="text-gradient">flpvvvv</span>
        </h1>

        <p class="hero-animate text-xl sm:text-2xl text-neutral-600 dark:text-neutral-400 max-w-2xl leading-relaxed mb-10">
          Exploring the intersection of <span class="font-mono text-primary-600 dark:text-primary-400 text-lg">statistics</span>, <span class="font-mono text-primary-600 dark:text-primary-400 text-lg">machine learning</span>, and the art of understanding data.
        </p>

        <div class="hero-animate flex flex-wrap gap-4">
          <a href="/posts" class="btn-primary">
            Read Posts
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
          <a href="/about" class="btn-secondary">
            About Me
          </a>
        </div>
      </div>
    </div>

    <!-- Subtle gradient at bottom -->
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-neutral-200 dark:via-neutral-800 to-transparent"></div>
  </section>

  <!-- Featured Posts -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
    <div class="flex items-end justify-between mb-10">
      <div>
        <h2 class="text-display font-bold text-neutral-900 dark:text-neutral-100 tracking-tight">
          Recent Posts
        </h2>
        <p class="text-neutral-500 dark:text-neutral-400 mt-2">Notes on statistics and data science</p>
      </div>
      <a href="/posts" class="font-mono text-sm text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300 transition-colors flex items-center gap-1">
        View all
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>

    <div class="space-y-4">
      {posts.slice(0, 5).map((post, index) => {
        const formattedDate = post.data.date.toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'short',
          day: 'numeric',
        });
        const words = post.body?.split(/\s+/).length || 0;
        const readingTime = Math.max(1, Math.ceil(words / 200));

        return (
          <a href={`/posts/${post.slug}`} class="group block card p-6 sm:p-8">
            <div class="flex flex-col sm:flex-row sm:items-start gap-4">
              <!-- Date on left for larger screens -->
              <div class="hidden sm:block w-28 flex-shrink-0 pt-1">
                <time datetime={post.data.date.toISOString()} class="font-mono text-sm text-neutral-400 dark:text-neutral-500">
                  {formattedDate}
                </time>
              </div>

              <div class="flex-grow">
                <div class="flex items-start justify-between gap-4 mb-2">
                  <!-- Date for mobile -->
                  <time datetime={post.data.date.toISOString()} class="sm:hidden font-mono text-xs text-neutral-400 dark:text-neutral-500 mb-2">
                    {formattedDate}
                  </time>

                  <h3 class="text-lg sm:text-xl font-semibold text-neutral-900 dark:text-neutral-100 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
                    {post.data.title}
                  </h3>
                </div>

                {post.data.description && (
                  <p class="text-neutral-600 dark:text-neutral-400 text-sm sm:text-base mb-4 line-clamp-2 leading-relaxed">
                    {post.data.description}
                  </p>
                )}

                <div class="flex items-center gap-4 text-sm">
                  <span class="text-neutral-400 dark:text-neutral-500 font-mono">
                    {readingTime} min
                  </span>
                  {post.data.tags.length > 0 && (
                    <div class="flex items-center gap-2">
                      {post.data.tags.slice(0, 2).map((tag: string) => (
                        <span class="text-xs font-mono text-primary-600/70 dark:text-primary-400/70">
                          #{tag}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </div>

              <!-- Arrow indicator -->
              <div class="hidden sm:flex items-center justify-center w-10 h-10 rounded-full border border-neutral-200 dark:border-neutral-700 group-hover:border-primary-400 dark:group-hover:border-primary-500 group-hover:bg-primary-50 dark:group-hover:bg-primary-950/30 transition-all duration-200 flex-shrink-0">
                <svg class="w-4 h-4 text-neutral-400 dark:text-neutral-500 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <!-- Tags Section -->
  {allTags.length > 0 && (
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
      <div class="card p-8 sm:p-10">
        <h2 class="text-heading font-bold text-neutral-900 dark:text-neutral-100 mb-6 tracking-tight">
          Topics
        </h2>
        <div class="flex flex-wrap gap-2">
          {allTags.map(tag => (
            <a href={`/tags/${tag.toLowerCase()}`} class="tag">
              {tag}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>