---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('posts'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Get unique tags
const allTags = [...new Set(posts.flatMap(post => post.data.tags))];
---

<BaseLayout title="Home">
  <!-- Hero Section -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
    <div class="text-center">
      <h1 class="font-sans text-4xl sm:text-5xl lg:text-6xl font-bold text-neutral-900 dark:text-neutral-100 mb-6">
        Hello, I'm <span class="text-primary-600 dark:text-primary-400">flpvvvv</span>
      </h1>
      <p class="font-serif text-xl sm:text-2xl text-neutral-600 dark:text-neutral-400 max-w-2xl mx-auto leading-relaxed">
        Data Scientist exploring the intersection of <span class="font-mono text-primary-600 dark:text-primary-400">statistics</span>, <span class="font-mono text-primary-600 dark:text-primary-400">machine learning</span>, and the art of understanding data.
      </p>
      <div class="mt-8 flex justify-center gap-4">
        <a href="/posts" class="inline-flex items-center px-6 py-3 border border-transparent text-sm font-medium rounded-lg text-white bg-primary-600 hover:bg-primary-700 dark:bg-primary-500 dark:hover:bg-primary-600 transition-colors">
          Read Posts
        </a>
        <a href="/about" class="inline-flex items-center px-6 py-3 border border-neutral-300 dark:border-neutral-600 text-sm font-medium rounded-lg text-neutral-700 dark:text-neutral-300 bg-white dark:bg-neutral-800 hover:bg-neutral-50 dark:hover:bg-neutral-700 transition-colors">
          About Me
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Posts -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="font-sans text-2xl font-bold text-neutral-900 dark:text-neutral-100">
        Recent Posts
      </h2>
      <a href="/posts" class="text-sm font-medium text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300 transition-colors">
        View all &rarr;
      </a>
    </div>

    <div class="space-y-6">
      {posts.slice(0, 5).map(post => {
        const formattedDate = post.data.date.toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'short',
          day: 'numeric',
        });
        const words = post.body?.split(/\s+/).length || 0;
        const readingTime = Math.max(1, Math.ceil(words / 200));

        return (
          <a href={`/posts/${post.slug}`} class="group block p-6 card">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-2">
              <h3 class="font-sans text-lg font-semibold text-neutral-900 dark:text-neutral-100 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
                {post.data.title}
              </h3>
              <time datetime={post.data.date.toISOString()} class="text-sm text-neutral-500 dark:text-neutral-400 whitespace-nowrap">
                {formattedDate}
              </time>
            </div>
            {post.data.description && (
              <p class="text-neutral-600 dark:text-neutral-400 text-sm mb-3 line-clamp-2">
                {post.data.description}
              </p>
            )}
            <div class="flex items-center gap-4 text-xs text-neutral-500 dark:text-neutral-400">
              <span>{readingTime} min read</span>
              {post.data.tags.length > 0 && (
                <div class="flex items-center gap-2">
                  {post.data.tags.slice(0, 2).map((tag: string) => (
                    <span class="font-mono">{tag}</span>
                  ))}
                </div>
              )}
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <!-- Tags Section -->
  {allTags.length > 0 && (
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
      <h2 class="font-sans text-2xl font-bold text-neutral-900 dark:text-neutral-100 mb-6">
        Topics
      </h2>
      <div class="flex flex-wrap gap-3">
        {allTags.map(tag => (
          <a href={`/tags/${tag.toLowerCase()}`} class="tag">
            {tag}
          </a>
        ))}
      </div>
    </section>
  )}
</BaseLayout>